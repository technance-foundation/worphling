{
    "author": "Technance <dev@technance.io>",
    "engines": {
        "node": ">=24.14.0"
    },
    "bin": {
        "worphling": "dist/index.mjs"
    },
    "dependencies": {
        "@formatjs/icu-messageformat-parser": "catalog:",
        "lodash-es": "catalog:",
        "minimist": "catalog:",
        "openai": "catalog:",
        "picocolors": "catalog:"
    },
    "description": "Simplify your translation workflow using Worphling. Synchronize translations and automate.",
    "devDependencies": {
        "@types/lodash-es": "catalog:",
        "@types/minimist": "catalog:",
        "@types/node": "catalog:",
        "tsdown": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "exports": {
        ".": "./dist/index.mjs"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "translation",
        "cli",
        "automation",
        "localization",
        "i18n"
    ],
    "license": "MIT",
    "main": "dist/index.mjs",
    "name": "@technance/worphling",
    "scripts": {
        "build": "tsdown",
        "build:dev": "tsdown --watch",
        "dev": "tsx watch src/index.ts",
        "release": "pnpm build && npm publish",
        "start": "node dist/index.mjs",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "pnpm build"
    },
    "type": "module",
    "types": "dist/index.d.mts",
    "version": "4.0.2"
}
