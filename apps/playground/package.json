{
    "dependencies": {
        "@technance/worphling": "workspace:*",
        "dotenv": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:"
    },
    "name": "@technance/worphling-playground",
    "private": true,
    "scripts": {
        "start": "worphling",
        "check": "worphling check",
        "check:ci": "worphling check --ci",
        "sync": "worphling sync --write",
        "translate": "worphling translate --write",
        "fix": "worphling fix --write",
        "report": "worphling report --report-file ./artifacts/worphling-report.md"
    },
    "type": "module",
    "version": "0.0.0"
}
